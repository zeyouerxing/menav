---
import DefaultLayout from '../layouts/DefaultLayout.astro';
import { loadConfig } from '../lib/config/index.ts';
import { buildSiteModel } from '../lib/site-model/index.ts';
import { collectSiteExternalData } from '../lib/site-model/external-data.ts';
import { generateFontCss, generateFontLinks } from '../lib/html/fonts.ts';

const config = loadConfig();
const model = buildSiteModel({ config, externalData: collectSiteExternalData(config) });
const renderData = {
  config: model.config,
  pages: model.pages,
  navigationData: model.navigationData,
  renderContext: model.renderContext,
  fontLinks: generateFontLinks(model.config),
  fontCss: generateFontCss(model.config),
  currentYear: model.meta.generatedAt.getFullYear(),
  runtimeConfigJson: model.runtimeConfigJson,
  version: model.meta.version,
};
---

<DefaultLayout {...renderData} />
