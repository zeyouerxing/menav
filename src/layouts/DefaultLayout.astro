---
import Navigation from '../components/Navigation.astro';
import PageContent from '../components/PageContent.astro';
import RuntimeScripts from '../components/RuntimeScripts.astro';
import SearchBar from '../components/SearchBar.astro';
import SocialLinks from '../components/SocialLinks.astro';
import ThemePreloadScript from '../components/ThemePreloadScript.astro';
import type { NavigationItem, ResolvedConfig } from '../types/config';
import type { PageEntry } from '../types/page';
import type { RenderContext } from '../types/render';

interface Props {
  config: ResolvedConfig;
  pages?: PageEntry[];
  navigationData?: NavigationItem[];
  renderContext?: RenderContext;
  fontLinks?: string;
  fontCss?: string;
  currentYear?: number;
  runtimeConfigJson?: string;
  version?: string;
}

const {
  config,
  pages = [],
  navigationData = [],
  renderContext,
  fontLinks = '',
  fontCss = '',
  currentYear,
  runtimeConfigJson = '{}',
  version = '',
} = Astro.props;

const site = config.site || {};
const themeMode = site.theme?.mode || 'dark';
const favicon = site.favicon || 'menav.svg';
const fontAwesomeCssUrl =
  'https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css';
const fontAwesomePreload = `<link rel="preload" href="${fontAwesomeCssUrl}" as="style" onload="this.onload=null;this.rel='stylesheet'" />`;
---

<!doctype html>
<html lang="zh-CN" data-theme-mode={themeMode}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="menav-version" content={version} />
    <title data-editable="site-title">{site.title}</title>
    <meta name="description" content={site.description} data-editable="site-description" />
    <meta name="author" content={site.author} data-editable="site-author" />
    <link rel="icon" href={`./${favicon}`} type="image/x-icon" />
    <link rel="shortcut icon" href={`./${favicon}`} type="image/x-icon" />
    <Fragment set:html={fontLinks} />
    <style set:html={fontCss}></style>
    <ThemePreloadScript />
    <link rel="stylesheet" href="./assets/style.css" />
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />
    <Fragment set:html={fontAwesomePreload} />
    <noscript>
      <link rel="stylesheet" href={fontAwesomeCssUrl} />
    </noscript>
  </head>
  <body class="loading">
    <div class="layout">
      <div class="mobile-buttons">
        <button class="menu-toggle" aria-label="切换菜单">
          <i class="fas fa-bars"></i>
        </button>
        <button class="search-toggle" aria-label="切换搜索">
          <i class="fas fa-search"></i>
        </button>
      </div>

      <div class="overlay"></div>

      <nav class="sidebar">
        <div class="logo">
          <div class="logo-brand">
            {
              site.favicon && (
                <img
                  class="logo-image"
                  src={`./${site.favicon}`}
                  alt={`${site.title} logo`}
                  width="26"
                  height="26"
                />
              )
            }
            <h1 data-editable="logo-text">{site.logo_text}</h1>
          </div>
          <button class="sidebar-toggle" aria-label="收起/展开侧边栏">
            <i class="fas fa-chevron-left toggle-icon"></i>
          </button>
        </div>

        <div class="sidebar-content">
          <div class="nav-section">
            <Navigation navigation={navigationData} />
          </div>
          <div class="sidebar-submenu-panel" aria-label="页面分类" data-container="sidebar-submenu">
          </div>
        </div>

        <div class="sidebar-social" data-container="social-links">
          <SocialLinks social={config.social || []} />
        </div>

        <div class="sidebar-footer">
          <div class="copyright">
            <p>
              © {currentYear}
              <a href="https://github.com/rbetree/menav" target="_blank" rel="noopener">MeNav</a>
            </p>
            <p>
              by <a href="https://github.com/rbetree" target="_blank" rel="noopener">rbetree</a>
            </p>
          </div>
        </div>
      </nav>

      <main class="content">
        <SearchBar />

        {
          pages.map((entry) => (
            <div class:list={['page', entry.id, entry.isActive && 'active']} id={entry.id}>
              <PageContent
                page={entry.data}
                templateName={entry.templateName}
                renderContext={renderContext}
              />
            </div>
          ))
        }
      </main>

      <button class="category-toggle" id="category-toggle" aria-label="展开/收起分类">
        <i class="fas fa-angle-double-down"></i>
      </button>

      <button class="theme-toggle" aria-label="切换主题">
        <i class="fas fa-moon"></i>
      </button>
    </div>

    <RuntimeScripts runtimeConfigJson={runtimeConfigJson} />
  </body>
</html>
