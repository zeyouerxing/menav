---
import Group from './Group.astro';
import SiteCard from './SiteCard.astro';
import type { GroupItem } from '../types/page';
import type { RenderContext } from '../types/render';
import { DEFAULT_RENDER_CONTEXT } from '../lib/view-data/render-context.ts';

interface Props {
  group?: GroupItem;
  level?: number;
  renderContext?: RenderContext;
}

const { group = {}, level = 3, renderContext = DEFAULT_RENDER_CONTEXT } = Astro.props;
const groupLevel = group.level || level || 3;
const headingLevel = Math.min(groupLevel + 1, 6);
const HeadingTag = `h${headingLevel}`;
const subgroups = Array.isArray(group.subgroups) ? group.subgroups : [];
const cards = Array.isArray(group.cards) ? group.cards : [];
const hasSubgroups = subgroups.length > 0;
const hasCards = cards.length > 0;
const isToggleable = hasSubgroups || hasCards;
---

<div
  class:list={['group', `group-level-${groupLevel}`]}
  data-type="group"
  data-name={group.name}
  data-icon={group.icon}
  data-level={groupLevel}
>
  <div class="group-header" data-toggle={isToggleable ? 'group' : undefined}>
    <HeadingTag data-editable="group-name">
      <i class={group.icon}></i>
      {group.name}
      {
        isToggleable && (
          <span class="toggle-icon">
            <i class="fas fa-chevron-down" />
          </span>
        )
      }
    </HeadingTag>
  </div>

  <div class="group-content">
    {
      hasSubgroups && (
        <div class="subgroups-container" data-container="subgroups">
          {subgroups.map((subgroup) => (
            <Group group={subgroup} level={4} renderContext={renderContext} />
          ))}
        </div>
      )
    }

    {
      hasCards && (
        <div class="sites-grid" data-container="sites">
          {cards.map((card) => (
            <SiteCard card={card} renderContext={renderContext} />
          ))}
        </div>
      )
    }

    {!hasSubgroups && !hasCards && <p class="empty-content">暂无网站</p>}
  </div>
</div>
