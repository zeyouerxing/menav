---
import Category from './Category.astro';
import Group from './Group.astro';
import SiteCard from './SiteCard.astro';
import type { CategoryItem } from '../types/page';
import type { RenderContext } from '../types/render';
import { DEFAULT_RENDER_CONTEXT } from '../lib/view-data/render-context.ts';

interface Props {
  category?: CategoryItem;
  level?: number;
  renderContext?: RenderContext;
}

const { category = {}, level = 1, renderContext = DEFAULT_RENDER_CONTEXT } = Astro.props;
const categoryLevel = category.level || level || 1;
const headingLevel = Math.min(categoryLevel + 1, 6);
const HeadingTag = `h${headingLevel}`;
const id = category.slug || category.name;
const subcategories = Array.isArray(category.subcategories) ? category.subcategories : [];
const groups = Array.isArray(category.groups) ? category.groups : [];
const cards = Array.isArray(category.cards) ? category.cards : [];
const hasSubcategories = subcategories.length > 0;
const hasGroups = groups.length > 0;
const hasCards = cards.length > 0;
const isToggleable = hasSubcategories || hasGroups || hasCards;
---

<section
  class:list={['category', `category-level-${categoryLevel}`]}
  id={id}
  data-type="category"
  data-id={id}
  data-name={category.name}
  data-icon={category.icon}
  data-level={categoryLevel}
  data-container="categories"
>
  <div class="category-header" data-toggle={isToggleable ? 'category' : undefined}>
    <HeadingTag data-editable="category-name">
      <i class={category.icon}></i>
      {category.name}
      {
        isToggleable && (
          <span class="toggle-icon">
            <i class="fas fa-chevron-down" />
          </span>
        )
      }
    </HeadingTag>
  </div>

  <div class="category-content">
    {
      hasSubcategories && (
        <div class="subcategories-container" data-container="subcategories">
          {subcategories.map((subCategory) => (
            <Category
              category={subCategory}
              level={categoryLevel + 1}
              renderContext={renderContext}
            />
          ))}
        </div>
      )
    }

    {
      hasGroups && (
        <div class="groups-container" data-container="groups">
          {groups.map((group) => (
            <Group group={group} renderContext={renderContext} />
          ))}
        </div>
      )
    }

    {
      hasCards && (
        <div class="sites-grid" data-container="sites">
          {cards.map((card) => (
            <SiteCard card={card} renderContext={renderContext} />
          ))}
        </div>
      )
    }

    {!hasSubcategories && !hasGroups && !hasCards && <p class="empty-content">暂无内容</p>}
  </div>
</section>
